# Optional: force API base URL (same Wi‑Fi IP of your Mac running the backend).
# Use when Expo auto-detection is wrong or you switch networks often.
# Restart Expo after changing.
# EXPO_PUBLIC_API_BASE_URL=http://192.168.1.42:8000

# Groq (only if you call Groq from the app directly; apartment chat uses the backend)
# EXPO_PUBLIC_GROQ_API_KEY=
